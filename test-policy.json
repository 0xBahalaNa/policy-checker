{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowS3Read",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": "arn:aws:s3:::my-bucket/*"
      },
      {
        "Sid": "DangerousAdmin01",
        "Effect": "Allow",
        "Action": "*",
        "Resource": "*"
      },
      {
        "Sid": "DangerousAdmin02",
        "Effect": "Allow",
        "Action": "*",
        "Resource": "*"
      }
    ]
  }