{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowS3Read",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": "arn:aws:s3:::my-bucket/*"
      },
      {
        "Sid": "DangerousAdmin01",
        "Effect": "Allow",
        "Action": "*",
        "Resource": "*"
      },
      {
        "Sid": "DangerousAdmin02",
        "Effect": "Allow",
        "Action": "*",
        "Resource": "*"
      },
      {
        "Sid": "DenyAll",
        "Effect": "Deny",
        "Action": "*",
        "Resource": "*"
      },
      {
        "Sid": "ServiceWildcardList",
        "Effect": "Allow",
        "Action": ["s3:GetObject", "iam:*"],
        "Resource": "*"
      },
      {
        "Sid": "ServiceWildcardString",
        "Effect": "Allow",
        "Action": "s3:*",
        "Resource": "*"
      },
      {
        "Sid": "CJIAccessNoMFA",
        "Effect": "Allow",
        "Action": "s3:GetObject",
        "Resource": "arn:aws:s3:::cji-data-bucket/*"
      },
      {
        "Sid": "CJICrossAccount",
        "Effect": "Allow",
        "Action": "s3:GetObject",
        "Resource": "arn:aws:s3:::cji-evidence-store/*",
        "Principal": {
          "AWS": "arn:aws:iam::123456789012:root"
        }
      }
    ]
  }
  